{
  "name": "haier-topbar-dark-scroll-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:auto": "node scripts/start-available-port.mjs --mode dev",
    "validate:dashboard": "node scripts/validate-dashboard-contract.mjs",
    "build": "npm run validate:dashboard && vue-tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "preview:auto": "node scripts/start-available-port.mjs --mode preview"
  },
  "dependencies": {
    "@lucide/vue": "^1.16.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "axios": "^1.17.0",
    "echarts": "^6.1.0",
    "element-plus": "^2.14.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
  },
  "devDependencies": {
    "@types/node": "^25.9.1"
  }
}
